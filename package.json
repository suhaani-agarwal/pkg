{
  "name": "my-app",
  "version": "0.0.1",
  "private": true,
  "description": "Alpic MCP Server Template",
  "type": "module",
  "scripts": {
    "dev": "skybridge dev",
    "dev:tunnel": "skybridge dev --tunnel",
    "dev:infra": "COMPOSE_IGNORE_ORPHANS=true docker compose -f docker-compose.infra.yml up -d && bash scripts/apply-hasura-metadata.sh",
    "dev:infra:down": "COMPOSE_IGNORE_ORPHANS=true docker compose -f docker-compose.infra.yml down",
    "seed:postgres": "bash scripts/seed-postgres.sh",
    "build": "skybridge build && npm run build:portal",
    "build:portal": "vite build --config vite.portal.config.ts && cp public/portal/portal.html public/portal/index.html",
    "dev:portal": "vite --config vite.portal.config.ts --port 3001",
    "start": "skybridge start",
    "deploy": "alpic deploy",
    "eval": "set -a && source .env && set +a && cd evals && promptfoo eval --config promptfoo.yaml --output results.json && cd .. && npx tsx scripts/eval-report.ts evals/results.json",
    "eval:quick": "set -a && source .env && set +a && cd evals && promptfoo eval --config promptfoo-quick.yaml",
    "eval:report": "npx tsx scripts/eval-report.ts evals/results.json",
    "eval:watch": "promptfoo eval --config evals/promptfoo.yaml --watch"
  },
  "dependencies": {
    "@alpic-ai/ui": "^1.122.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/express-session": "^1.19.0",
    "@types/leaflet": "^1.9.21",
    "dotenv": "^17.4.2",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "express-session": "^1.19.0",
    "graphql": "^16.14.1",
    "graphql-http": "^1.22.4",
    "graphql-request": "^7.4.0",
    "langfuse": "^3.38.20",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "nodemon": "^3.1.14",
    "openapi-to-graphql": "^3.0.7",
    "openid-client": "^6.8.4",
    "pako": "^2.1.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.16.0",
    "skybridge": "^1.0.2",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@skybridge/devtools": "^1.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "alpic": "^1.104.1",
    "promptfoo": "^0.121.17",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
